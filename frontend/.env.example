# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_BASE_PATH=/api

# App Configuration
VITE_APP_TITLE=Recruitment Suite
VITE_APP_VERSION=1.0.0
VITE_LOG_LEVEL=info

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_NOTIFICATIONS=true

# Authentication
VITE_AUTH_STORAGE_KEY=recruitment_suite_token
VITE_AUTH_REDIRECT_LOGIN=/login
VITE_AUTH_REDIRECT_LOGOUT=/
