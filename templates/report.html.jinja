<!DOCTYPE html>
<html lang="{{ language[:2] }}">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ 'report.title' | t(language) }} — {{ candidate_name }}</title>
<style>
  :root{
    --ava-orange:#FF5800; --ava-dark-orange:#DC4600; --ava-black:#000; --ava-white:#fff;
    --g80:#333; --g70:#4c4c4c; --g60:#666; --g50:#7f7f7f; --g40:#999; --g30:#b3b3b3; --g20:#ccc; --g10:#e5e5e5;
    --solar:#FFD700; --luminous:#FFB414; --glow:#FF5800; --flame:#B43C14; --thermal:#C80000; --aurora:#890078;
    --success:#00A650; --warn:#C77700; --danger:#C80000; --info:#0078D4;
    --master:linear-gradient(135deg,#FF5800 0%,#890078 100%);
    --warm:linear-gradient(135deg,#FFD700 0%,#FF5800 100%);
    --font:'Segoe UI','Segoe UI Variable',system-ui,-apple-system,BlinkMacSystemFont,'Helvetica Neue',Arial,sans-serif;
    --shadow-md:0 4px 12px rgba(0,0,0,.10);
    --shadow-lg:0 8px 24px rgba(0,0,0,.12);
    --shadow-brand:0 4px 20px rgba(255,88,0,.28);
  }
  *{box-sizing:border-box;margin:0;padding:0}
  html{scroll-behavior:smooth}
  body{font-family:var(--font);color:var(--g80);background:#fafafa;line-height:1.55;-webkit-font-smoothing:antialiased}
  .wrap{max-width:900px;margin:0 auto;padding:0 24px}
  ul{list-style:none}

  /* ---------- HERO ---------- */
  .hero{background:var(--master);color:#fff;padding:56px 0 48px;position:relative;overflow:hidden}
  .hero::after{content:"";position:absolute;right:-120px;top:-120px;width:420px;height:420px;
    background:radial-gradient(circle,rgba(255,215,0,.4) 0%,rgba(255,215,0,0) 70%);pointer-events:none}
  .kicker{font-size:12px;font-weight:600;letter-spacing:.14em;text-transform:uppercase;opacity:.9;margin-bottom:16px;position:relative;z-index:1}
  .hero h1{font-weight:300;font-size:clamp(26px,4.4vw,40px);line-height:1.1;margin-bottom:10px;position:relative;z-index:1}
  .hero h1 strong{font-weight:700}
  .hero .lede{font-size:14.5px;font-weight:400;opacity:.95;position:relative;z-index:1}
  .hero-meta{margin-top:22px;display:flex;flex-wrap:wrap;gap:10px;position:relative;z-index:1}
  .pill{background:rgba(255,255,255,.16);border:1px solid rgba(255,255,255,.3);backdrop-filter:blur(4px);
    border-radius:999px;padding:6px 14px;font-size:12.5px;font-weight:600}

  /* ---------- ARC / SCORE STRIP ---------- */
  .arc{background:#fff;border-top:4px solid var(--ava-orange);box-shadow:var(--shadow-md);position:relative;z-index:2}
  .arc .wrap{display:grid;grid-template-columns:repeat(3,1fr);gap:0;padding:0}
  .arc .cell{padding:24px 24px}
  .arc .cell + .cell{border-left:1px solid var(--g10)}
  .arc .big{font-weight:700;font-size:36px;line-height:1;letter-spacing:-.02em}
  .arc .lbl{font-weight:600;font-size:13px;color:var(--g80);margin-top:6px}
  .arc .sub{font-size:12px;color:var(--g60);margin-top:3px}

  section{padding:44px 0}
  .eyebrow{font-size:11px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;color:var(--ava-dark-orange);margin-bottom:10px}
  h2.h{font-weight:300;font-size:clamp(20px,3vw,26px);line-height:1.2;color:var(--g80);margin-bottom:8px}
  h2.h b{font-weight:600}
  .section-intro{font-size:14px;color:var(--g60);max-width:64ch;margin-bottom:24px}
  .bar-rule{width:44px;height:4px;background:var(--ava-orange);border-radius:2px;margin-bottom:18px}

  /* ---------- LAYERS (score dimensions accordion) ---------- */
  .stack{display:flex;flex-direction:column;gap:12px}
  .layer{background:#fff;border:1px solid var(--g10);border-radius:8px;box-shadow:var(--shadow-md);
    overflow:hidden;cursor:pointer;transition:transform .18s ease,box-shadow .18s ease}
  .layer:hover{transform:translateY(-1px);box-shadow:var(--shadow-lg)}
  .layer-head{display:grid;grid-template-columns:6px 1fr auto auto;align-items:center;gap:16px;padding:18px 20px}
  .layer .spine{width:6px;align-self:stretch;border-radius:3px}
  .layer .title h3{font-weight:600;font-size:16.5px;color:var(--g80)}
  .layer .title .desc{font-size:13px;color:var(--g60);margin-top:3px}
  .layer .save{font-weight:700;font-size:22px;white-space:nowrap}
  .layer .chev{width:24px;height:24px;border-radius:50%;background:var(--g10);display:grid;place-items:center;
    color:var(--g60);font-size:13px;transition:transform .2s ease;flex-shrink:0}
  .layer.open .chev{transform:rotate(180deg)}
  .layer-body{max-height:0;overflow:hidden;transition:max-height .32s ease;background:#fcfcfc}
  .layer.open .layer-body{max-height:2000px;border-top:1px solid var(--g10)}
  .layer-body .inner{padding:18px 20px 20px}
  .layer-body p{font-size:13.5px;color:var(--g70);margin:0 0 .6rem}
  .layer-body p:last-child{margin-bottom:0}
  .dim-table{width:100%;font-size:12.5px;margin-top:.6rem;border-collapse:collapse}
  .dim-table td,.dim-table th{padding:.4rem .5rem;border-bottom:1px solid var(--g10);text-align:left;vertical-align:top}
  .tag-gap{color:var(--warn)}
  .tag-strength{color:var(--success)}

  /* ---------- SURFACES (lists: strengths / gaps / flags) ---------- */
  .surfaces{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:14px}
  .surf{background:#fff;border:1px solid var(--g10);border-radius:8px;padding:20px;box-shadow:var(--shadow-md);
    border-top:3px solid var(--ava-orange)}
  .surf.gaps{border-top-color:var(--warn)}
  .surf.flags{border-top-color:var(--danger)}
  .surf h3{font-weight:600;font-size:15px;margin-bottom:10px;color:var(--g80)}
  .surf li{font-size:13.5px;color:var(--g70);padding-left:16px;position:relative;margin:6px 0}
  .surf li::before{content:"";position:absolute;left:0;top:7px;width:6px;height:6px;border-radius:50%;background:var(--ava-orange)}
  .surf.gaps li::before{background:var(--warn)}
  .surf.flags li::before{background:var(--danger)}
  .surf .empty{color:var(--g40);font-style:italic}

  /* ---------- PULL QUOTE (rationale) ---------- */
  .pq{background:var(--ava-orange);color:#fff;border-radius:12px;padding:36px 36px;text-align:center;box-shadow:var(--shadow-brand)}
  .pq .q{font-weight:300;font-size:clamp(18px,2.6vw,26px);line-height:1.3;max-width:44ch;margin:0 auto}
  .pq .attr{margin-top:14px;font-size:13px;font-weight:600;opacity:.9;letter-spacing:.03em}

  /* ---------- ROADMAP (next steps + onboarding) ---------- */
  .road{display:grid;grid-template-columns:1fr 1fr;gap:12px}
  .step{background:#fff;border:1px solid var(--g10);border-radius:8px;padding:16px 18px;display:flex;gap:14px;
    box-shadow:var(--shadow-md);transition:border-color .18s;align-items:flex-start}
  .step:hover{border-color:var(--ava-orange)}
  .step .sn{flex:0 0 32px;height:32px;border-radius:50%;background:var(--warm);color:#fff;font-weight:700;
    display:grid;place-items:center;font-size:14px}
  .step p{font-size:13.5px;color:var(--g70);line-height:1.4}

  /* ---------- Interview notes ---------- */
  .notes-card{background:#fff;border:1px solid var(--g10);border-left:4px solid var(--aurora);border-radius:8px;
    padding:22px 24px;box-shadow:var(--shadow-md)}
  .notes-card p{font-size:13.5px;color:var(--g70);margin:0 0 .6rem}
  .notes-card p:last-child{margin-bottom:0}

  /* ---------- FOOTER ---------- */
  footer{background:var(--g80);color:var(--g30);padding:36px 0}
  footer .ftop{display:flex;justify-content:space-between;align-items:flex-end;flex-wrap:wrap;gap:16px}
  .wordmark{color:#fff;font-weight:700;font-size:18px;letter-spacing:-.01em}
  .wordmark span{color:var(--ava-orange)}
  .wm-sub{font-size:11.5px;color:var(--g40);font-weight:400;margin-top:3px}
  footer .fnotes{font-size:11px;color:var(--g40);margin-top:18px;line-height:1.6}

  /* ---------- Export toolbar (screen-only) ---------- */
  .export-toolbar{position:fixed;top:1rem;right:1rem;z-index:40;display:flex;gap:.5rem}
  .export-btn{display:inline-flex;align-items:center;gap:.4rem;background:#111827;color:#fff;border:none;
    border-radius:8px;padding:.55rem 1rem;font-size:.82rem;font-weight:600;cursor:pointer;box-shadow:0 4px 10px rgba(0,0,0,.2)}
  .export-btn:hover{background:#1f2937}

  @media (max-width:640px){
    .arc .wrap{grid-template-columns:1fr}
    .arc .cell + .cell{border-left:none;border-top:1px solid var(--g10)}
    .surfaces,.road{grid-template-columns:1fr}
    .layer-head{grid-template-columns:6px 1fr auto}
    .layer .chev{display:none}
  }
  @media print{
    body{background:#fff}
    .layer-body{max-height:none!important}
    .layer .chev{display:none}
    .hero::after{display:none}
    .export-toolbar{display:none}
    .layer-head{cursor:default}
    section{padding:24px 0}
  }
</style>
</head>
<body>
<div class="export-toolbar">
  <button class="export-btn" onclick="window.print()">🖨️ {{ 'report.export_pdf' | t(language) }}</button>
</div>

{% set status_keys = {"GO": "report.status_go", "HOLD": "report.status_hold", "NO_GO": "report.status_no_go"} %}
{% set status_colors = {"GO": "#00A650", "HOLD": "#FFB414", "NO_GO": "#C80000"} %}

<!-- HERO -->
<header class="hero">
  <div class="wrap">
    <div class="kicker">{{ 'report.title' | t(language) }}</div>
    <h1>{{ candidate_name }}</h1>
    <p class="lede">{{ 'report.job' | t(language) }}: {{ job_title }}{% if job_company %} {{ 'report.at' | t(language) }} {{ job_company }}{% endif %}</p>
    <div class="hero-meta">
      <span class="pill">{{ 'report.confidence' | t(language) }}: {{ confidence }}%</span>
      <span class="pill">{{ 'report.generated' | t(language) }}: {{ generated_at }}</span>
    </div>
  </div>
</header>

<!-- ARC -->
<div class="arc">
  <div class="wrap">
    <div class="cell">
      <div class="big" style="color:{{ status_colors[recommendation] }}">{{ final_score }}<span style="font-size:18px;color:var(--g40)">/100</span></div>
      <div class="lbl">{{ status_keys[recommendation] | t(language) }}</div>
      {% if pre_interview_score is not none %}
      <div class="sub">{{ 'report.score_before_notes' | t(language) }}: {{ pre_interview_score }}/100{% if pre_interview_status %} ({{ status_keys[pre_interview_status] | t(language) }}){% endif %}</div>
      {% endif %}
    </div>
    <div class="cell">
      <div class="big" style="color:var(--aurora)">{{ confidence }}%</div>
      <div class="lbl">{{ 'report.confidence' | t(language) }}</div>
    </div>
    <div class="cell">
      <div class="big" style="color:var(--ava-dark-orange)">+{{ strategic_bonus }}</div>
      <div class="lbl">{{ 'report.strategic_bonus' | t(language) }}</div>
      <div class="sub">{{ 'report.strategic_bonus_tip' | t(language) }}</div>
    </div>
  </div>
</div>

{% set dim_keys = {
  "Profile": "dimension.profile",
  "Technical": "dimension.technical",
  "Culture Fit": "dimension.culture_fit",
  "References": "dimension.references",
} %}
{% set dim_tips = {
  "Profile": "report.profile_tip",
  "Technical": "report.technical_tip",
  "Culture Fit": "report.culture_fit_tip",
  "References": "report.references_tip",
} %}
{% set spine_colors = ["#FFD700", "#FF5800", "#B43C14", "#890078", "#0078D4"] %}

<!-- SCORE BREAKDOWN (accordion layers) -->
<section>
  <div class="wrap">
    <div class="bar-rule"></div>
    <div class="eyebrow">{{ 'report.score_breakdown' | t(language) }}</div>
    <h2 class="h">{{ 'report.score_breakdown_tip' | t(language) }}</h2>

    <div class="stack">
      {% set ns = namespace(i=0) %}
      {% for label, value in [
        ("Profile", profile_score),
        ("Technical", technical_score),
        ("Culture Fit", culture_score),
        ("References", reference_score),
      ] %}
      {% if label != "Technical" or people_analytics_score is none %}
      {% set ns.i = ns.i + 1 %}
      <article class="layer">
        <div class="layer-head" onclick="this.closest('.layer').classList.toggle('open')">
          <div class="spine" style="background:{{ spine_colors[(ns.i - 1) % spine_colors|length] }}"></div>
          <div class="title">
            <h3>{{ dim_keys[label] | t(language) }}</h3>
            <div class="desc">{{ dim_tips[label] | t(language) }}</div>
          </div>
          <div class="save" style="color:{{ '#00A650' if value >= 80 else ('#FFB414' if value >= 60 else '#C80000') }}">{{ value }}</div>
          <div class="chev">▾</div>
        </div>
        {% if agent_analysis.get(label) %}
        <div class="layer-body"><div class="inner">
          {{ agent_analysis[label].analysis | analysis_html }}
          {% if agent_analysis[label].dimensions %}
          <table class="dim-table">
            <tr><th>{{ 'report.dimension_col' | t(language) }}</th><th>{{ 'report.score_col' | t(language) }}</th><th>{{ 'report.weight_col' | t(language) }}</th><th>{{ 'report.notes_col' | t(language) }}</th></tr>
            {% for d in agent_analysis[label].dimensions %}
            <tr>
              <td>{{ d.dimension }}</td>
              <td>{{ d.score }}</td>
              <td>{{ (d.weight * 100) | round | int }}%</td>
              <td>
                {% for s in d.strengths %}<span class="tag-strength">✓ {{ s }}</span><br>{% endfor %}
                {% for g in d.gaps %}<span class="tag-gap">△ {{ g }}</span><br>{% endfor %}
              </td>
            </tr>
            {% endfor %}
          </table>
          {% endif %}
        </div></div>
        {% endif %}
      </article>
      {% endif %}
      {% endfor %}

      {% if people_analytics_score is not none %}
      {% set ns.i = ns.i + 1 %}
      <article class="layer">
        <div class="layer-head" onclick="this.closest('.layer').classList.toggle('open')">
          <div class="spine" style="background:{{ spine_colors[(ns.i - 1) % spine_colors|length] }}"></div>
          <div class="title">
            <h3>{{ 'dimension.people_analytics' | t(language) }}</h3>
            <div class="desc">{{ 'report.people_analytics_tip' | t(language) }}</div>
          </div>
          <div class="save" style="color:{{ '#00A650' if people_analytics_score >= 80 else ('#FFB414' if people_analytics_score >= 60 else '#C80000') }}">{{ people_analytics_score }}</div>
          <div class="chev">▾</div>
        </div>
        {% if agent_analysis.get("People Analytics") %}
        <div class="layer-body"><div class="inner">
          {{ agent_analysis["People Analytics"].analysis | analysis_html }}
          {% if agent_analysis["People Analytics"].dimensions %}
          <table class="dim-table">
            <tr><th>{{ 'report.dimension_col' | t(language) }}</th><th>{{ 'report.score_col' | t(language) }}</th><th>{{ 'report.weight_col' | t(language) }}</th><th>{{ 'report.notes_col' | t(language) }}</th></tr>
            {% for d in agent_analysis["People Analytics"].dimensions %}
            <tr>
              <td>{{ d.dimension }}</td>
              <td>{{ d.score }}</td>
              <td>{{ (d.weight * 100) | round | int }}%</td>
              <td>
                {% for s in d.strengths %}<span class="tag-strength">✓ {{ s }}</span><br>{% endfor %}
                {% for g in d.gaps %}<span class="tag-gap">△ {{ g }}</span><br>{% endfor %}
              </td>
            </tr>
            {% endfor %}
          </table>
          {% endif %}
        </div></div>
        {% endif %}
      </article>
      {% endif %}
    </div>
  </div>
</section>

<!-- STRENGTHS / GAPS / FLAGS -->
<section style="background:#fff;border-top:1px solid var(--g10);border-bottom:1px solid var(--g10)">
  <div class="wrap">
    <div class="bar-rule"></div>
    <div class="eyebrow">{{ 'report.key_strengths' | t(language) }} · {{ 'report.addressable_gaps' | t(language) }}</div>
    <h2 class="h">{{ 'report.key_strengths_tip' | t(language) }}</h2>

    <div class="surfaces">
      <div class="surf">
        <h3>{{ 'report.key_strengths' | t(language) }}</h3>
        <ul>
          {% for s in strengths %}<li>{{ s }}</li>{% else %}<li class="empty">{{ 'report.none_identified' | t(language) }}</li>{% endfor %}
        </ul>
      </div>
      <div class="surf gaps">
        <h3>{{ 'report.addressable_gaps' | t(language) }}</h3>
        <ul>
          {% for g in gaps %}<li>{{ g }}</li>{% else %}<li class="empty">{{ 'report.none_identified' | t(language) }}</li>{% endfor %}
        </ul>
      </div>
      {% if flags %}
      <div class="surf flags">
        <h3>{{ 'report.critical_flags' | t(language) }}</h3>
        <ul>
          {% for f in flags %}<li>⚠️ {{ f }}</li>{% endfor %}
        </ul>
      </div>
      {% endif %}
    </div>
  </div>
</section>

<!-- RATIONALE PULL QUOTE -->
<section style="padding-top:36px">
  <div class="wrap">
    <div class="pq">
      <div class="q">{{ rationale }}</div>
      <div class="attr">{{ status_keys[recommendation] | t(language) }} · {{ 'report.confidence' | t(language) }} {{ confidence }}%</div>
    </div>
  </div>
</section>

<!-- ROADMAP (next steps + onboarding) -->
<section style="background:#fff;border-top:1px solid var(--g10)">
  <div class="wrap">
    <div class="bar-rule"></div>
    <div class="eyebrow">{{ 'report.next_steps' | t(language) }}</div>
    <h2 class="h">{{ 'report.next_steps_tip' | t(language) }}</h2>
    <div class="road">
      {% for step in next_steps %}
      <div class="step"><div class="sn">{{ loop.index }}</div><p>{{ step }}</p></div>
      {% endfor %}
      {% if onboarding %}
        {% for item in onboarding %}
        <div class="step"><div class="sn">{{ next_steps|length + loop.index }}</div><p>{{ item }}</p></div>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% if interview_notes %}
<section>
  <div class="wrap">
    <div class="bar-rule"></div>
    <div class="eyebrow">{{ 'report.interview_notes' | t(language) }}</div>
    <h2 class="h">{{ 'report.interview_notes_tip' | t(language) }}</h2>
    <div class="notes-card">
      {{ interview_notes | analysis_html }}
      {% if notes_updated_at %}<p style="color:var(--g40); font-size:12px; margin-top:.8rem">{{ 'report.generated' | t(language) }}: {{ notes_updated_at }}</p>{% endif %}
    </div>
  </div>
</section>
{% endif %}

<!-- FOOTER -->
<footer>
  <div class="wrap">
    <div class="ftop">
      <div>
        <div class="wordmark">Recruitment Suite<span>.</span></div>
        <div class="wm-sub">{{ 'report.title' | t(language) }}</div>
      </div>
    </div>
    <div class="fnotes">
      {{ 'report.candidate' | t(language) }}: {{ candidate_name }} · {{ 'report.job' | t(language) }}: {{ job_title }}{% if job_company %} {{ 'report.at' | t(language) }} {{ job_company }}{% endif %} · {{ 'report.generated' | t(language) }}: {{ generated_at }}
    </div>
  </div>
</footer>

</body>
</html>
