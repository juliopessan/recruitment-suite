# Database Configuration
DATABASE_URL=sqlite:///./recruitment_suite.db
# For PostgreSQL: postgresql://user:password@localhost/recruitment_suite
# For MySQL: mysql://user:password@localhost/recruitment_suite

# SQL Echo (log all SQL statements)
SQL_ECHO=False

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=True
API_LOG_LEVEL=info

# CORS Configuration
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000"]

# Report Generation
TEMPLATE_DIR=templates
OUTPUT_DIR=reports

# Scoring Weights (optional, used by orchestrator)
PROFILE_WEIGHT=0.20
TECHNICAL_WEIGHT=0.35
CULTURE_WEIGHT=0.25
REFERENCE_WEIGHT=0.15
STRATEGIC_WEIGHT=0.05

# LinkedIn Integration (optional)
LINKEDIN_API_KEY=your_api_key_here

# Exa API (LinkedIn/profile enrichment) - https://exa.ai
EXA_API_KEY=your_exa_api_key_here
